{
  "expo": {
    "name": "PathFinder",
    "slug": "path-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.pathfinder.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "pathfinder",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-image-picker",
      "expo-document-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8aa8139-ab59-40cb-a743-0833582bf471"
      }
    },
    "owner": "starboyrohinth",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e8aa8139-ab59-40cb-a743-0833582bf471"
    }
  }
}
